# Contact details shown on the site
NEXT_PUBLIC_CONTACT_EMAIL=info@ksdiecrafts.com
NEXT_PUBLIC_CONTACT_PHONE=
NEXT_PUBLIC_CONTACT_WHATSAPP=

# Resend email delivery (server-side, used by /api/contact)
# Get an API key at https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxx
# Verified sender address (the domain must be verified in Resend)
RESEND_FROM_EMAIL=noreply@ksdiecrafts.com


EMAIL_PROVIDER=smtp
